{
  "_note": "Tabelle Calixto. eligibility (C8.5.2), piece_priorities (C8.5.8), effective_events (C8.5.5), propaganda (C8.5.9). space_selection (C8.5.6) e move_priorities (C8.5.7) sono matrici dense: in trascrizione con lettura ad alto zoom.",
  "eligibility": {
    "first": [
      {
        "cond": "gov_acting_and_underground_dr_or_26j_in_havana",
        "result": "op_sa"
      },
      {
        "cond": "current_event_critical_and_effective",
        "result": "event"
      },
      {
        "cond": "next_eligible_could_choose_effective_critical_event",
        "result": "op_only"
      },
      {
        "cond": "acting_faction_first_eligible_on_upcoming_critical_event",
        "result": "pass"
      },
      {
        "cond": "otherwise",
        "result": "op_and_sa"
      }
    ],
    "second": [
      {
        "cond": "first_eligible_on_upcoming_critical_and_cannot_execute_current_critical_effective",
        "result": "pass"
      },
      {
        "cond": "first_eligible_chose_event",
        "result": "op_sa"
      },
      {
        "cond": "first_eligible_chose_op_sa_and_current_event_critical_or_performed_and_effective",
        "result": "event"
      },
      {
        "cond": "acting_faction_first_eligible_on_upcoming_event",
        "result": "pass"
      },
      {
        "cond": "otherwise",
        "result": "lim_op"
      }
    ]
  },
  "piece_priorities": {
    "_note": "C8.5.8. Lettura: (A) muovi/rimuovi/sostituisci/attiva pezzi del giocatore prima di quelli NP. (B) dall'alto in basso e da sx a dx per muovere/rimuovere/sostituire/attivare pezzi nemici e piazzare/muovere pezzi amici. (C) dal basso in alto e da dx a sx per rimuovere pezzi amici.",
